rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Lesen: nur eigenes Profil
      allow read: if request.auth != null && request.auth.uid == uid;

      // Erstellen: eigenes Profil, aber isSapUser darf NICHT selbst gesetzt werden
      allow create: if request.auth != null
        && request.auth.uid == uid
        && !('isSapUser' in request.resource.data.keys() && request.resource.data.isSapUser == true);

      // Update: eigenes Profil, aber isSapUser-Feld darf nicht verändert werden
      allow update: if request.auth != null
        && request.auth.uid == uid
        && (!('isSapUser' in request.resource.data.diff(resource.data).affectedKeys()));

      // Löschen: eigenes Profil erlaubt
      allow delete: if request.auth != null && request.auth.uid == uid;

      match /progress/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
